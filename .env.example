# Timezone padrão para exibição
TZ=America/Sao_Paulo

# Configurações do Banco de Dados PostgreSQL
POSTGRES_USER=bolao_user
POSTGRES_PASSWORD=change_me_database_password
POSTGRES_DB=bolao_db
DATABASE_URL=postgresql://bolao_user:change_me_database_password@db:5432/bolao_db

# Configurações de Segurança do Backend
# Gere um segredo forte com: openssl rand -hex 32
JWT_SECRET=change_me_with_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3999

# Usuário Administrador Inicial (Bootstrap)
# Use true apenas na primeira execução, depois altere para false.
ENABLE_ADMIN_BOOTSTRAP=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_admin_password

# URLs dos arquivos do openfootball (Fontes de Dados)
TEAMS_JSON_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/refs/heads/master/2026/worldcup.teams.json
STADIUMS_JSON_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/refs/heads/master/2026/worldcup.stadiums.json
MATCHES_JSON_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/refs/heads/master/2026/worldcup.json

# Configurações de E-mail (SMTP)
SMTP_HOST=mail.example.internal
SMTP_PORT=25
SMTP_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_DOMAIN=example.com
SMTP_FROM=bolao@example.com

# URL pública do frontend, usada em links de e-mail de reset de senha
FRONTEND_URL=https://bolao.example.com

# Notificações WhatsApp via API interna
# Recomendado: coloque a API de mensagens na mesma rede Docker e use o nome do serviço.
WHATSAPP_NOTIFY_ENABLED=false
WHATSAPP_NOTIFY_URL=http://whatsgo-bot-1:9999/internal/v1/send
WHATSAPP_NOTIFY_TOKEN=change_me_whatsapp_internal_api_token
WHATSAPP_NOTIFY_TO=120363000000000000@g.us
WHATSAPP_NOTIFY_SEND_AS=text
WHATSAPP_NOTIFY_TIMEOUT_SECONDS=5
WHATSAPP_GROUP_CHAT=https://chat.whatsapp.com/change_me_invite_code

# Publicação externa dos blocos de auditoria dos palpites no GitHub
# O token precisa ter permissão de leitura/escrita em Contents no repositório alvo.
GITHUB_AUDIT=false
GITHUB_REPO=git@github.com:seu-usuario/palpites-copa-2026-auditoria.git
GITHUB_TOKEN=change_me_github_token_with_contents_write

# Backup manual para Telegram
TELEGRAM_BACKUP_BOT_TOKEN=change_me_telegram_bot_token
TELEGRAM_BACKUP_CHAT_ID=11223344

# Compatibilidade com versões anteriores da integração de aprovação de pagamento
PAYMENT_APPROVAL_NOTIFY_ENABLED=false
PAYMENT_APPROVAL_NOTIFY_URL=http://whatsgo-bot-1:9999/internal/v1/send
PAYMENT_APPROVAL_NOTIFY_TOKEN=change_me_whatsapp_internal_api_token
PAYMENT_APPROVAL_NOTIFY_TO=120363000000000000@g.us
PAYMENT_APPROVAL_NOTIFY_SEND_AS=text
PAYMENT_APPROVAL_NOTIFY_TIMEOUT_SECONDS=5

# Integrações Futuras (Keycloak / OAuth2) - Placeholders
KEYCLOAK_ENABLED=false
KEYCLOAK_SERVER_URL=http://localhost:8080/auth
KEYCLOAK_REALM=bolao-worldcup
KEYCLOAK_CLIENT_ID=bolao-app
KEYCLOAK_CLIENT_SECRET=change_me_keycloak_secret
